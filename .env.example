# 前端：GitHub Pages 构建时配置为 Vercel 项目完整 HTTPS 地址。
VITE_API_BASE_URL=https://your-image-api.vercel.app

# 后端：以下变量只放 Vercel Project Settings → Environment Variables。
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://wmww-g.github.io
GOOGLE_CLOUD_PROJECT=your-google-cloud-project
GOOGLE_CLOUD_LOCATION=global
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_PROMPT_PLANNER_MODEL=gemini-3.5-flash

OPENROUTER_API_KEY=replace-in-server-only
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_GPT_IMAGE_2_MODEL=openai/gpt-image-2
OPENROUTER_SITE_URL=https://wmww-g.github.io/PTJ_Prototype/
OPENROUTER_APP_NAME=PTJ Prototype

# 创建 Vercel Blob Store 后由 Vercel 自动注入；不要写进前端变量。
BLOB_READ_WRITE_TOKEN=replace-in-vercel-only
BLOB_ALLOWED_HOST=your-store.public.blob.vercel-storage.com

# 待接入的 Dify“生图固定工作流”。密钥只能放后端环境变量或密钥管理服务。
# 本机开发凭据保存在 macOS 钥匙串服务 PTJ_DIFY_FIXED_IMAGE_API_KEY 中。
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_FIXED_IMAGE_APP_ID=07afb65a-1d26-45d1-b312-5b1e91d37d40
DIFY_FIXED_IMAGE_API_KEY=replace-in-server-only
